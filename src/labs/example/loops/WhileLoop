package.labs.example.loops;

//step 1 of lab
public class WhileLoop {
    private static void executeWhileLoop(String[] args) {
        int number = 1
        while (number <= 9) {
            System.out.println("Loop iteration:" + number);
            number++;
        }
        System.out.println("The loop is now complete.");
    }
}